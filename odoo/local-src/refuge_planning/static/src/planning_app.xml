<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="refuge_planning.PlanningApp">
    <div>
      <AppHeader title="'Planning'"
                 subtitle="fmtWeek()"
                 showBack="true" backHref="'/refuge'" showLogout="true"/>

      <div class="rp-root">

        <div class="rp-toolbar">
          <button class="refuge-btn refuge-btn-ghost"
                  t-on-click="() => this.changeWeek(-7)">← Semaine précédente</button>
          <button class="refuge-btn refuge-btn-ghost"
                  t-on-click="() => this.changeWeek(7)">Semaine suivante →</button>
          <span class="rp-spacer"/>
          <t t-if="state.isAdmin">
            <button class="refuge-btn refuge-btn-primary"
                    t-on-click="generate" t-att-disabled="state.generating">
              <t t-if="state.generating">Génération…</t>
              <t t-else="">⚙ Générer la proposition</t>
            </button>
            <button t-if="draftCount > 0"
                    class="refuge-btn refuge-btn-primary rp-validate-btn"
                    t-on-click="validateWeek" t-att-disabled="state.validating">
              <t t-if="state.validating">Validation…</t>
              <t t-else="">✓ Valider la semaine (<t t-esc="draftCount"/> brouillon(s))</t>
            </button>
            <button class="refuge-btn refuge-btn-ghost"
                    t-on-click="openNewShift">
              + Ajouter un shift manuel
            </button>
          </t>
        </div>

        <nav class="rp-tabs">
          <button class="rp-tab"
                  t-att-class="state.tab === 'planning' ? 'is-active' : ''"
                  t-on-click="() => this.setTab('planning')">
            🗓 Planning
          </button>
          <button class="rp-tab"
                  t-att-class="state.tab === 'avail' ? 'is-active' : ''"
                  t-on-click="() => this.setTab('avail')">
            📋 Disponibilités
          </button>
          <button class="rp-tab"
                  t-att-class="state.tab === 'me' ? 'is-active' : ''"
                  t-on-click="() => this.setTab('me')">
            👤 Mon espace
          </button>
        </nav>

        <div t-if="state.error" class="refuge-planning-error">
          Erreur : <t t-esc="state.error"/>
        </div>
        <div t-if="state.lastReport and state.lastReport.uncovered and state.lastReport.uncovered.length"
             class="refuge-planning-warning">
          ⚠ <t t-esc="state.lastReport.uncovered.length"/> demi-heure(s) non couverte(s)
          après génération — voir détail ci-dessous.
        </div>

        <!-- ============================== Onglet PLANNING ============== -->
        <section t-if="state.tab === 'planning'" class="rp-tab-pane">
          <SummaryCards employees="state.employees" shifts="state.shifts"/>
          <WeekCalendar employees="state.employees"
                        shifts="state.shifts"
                        weekStart="state.weekStart"
                        canManage="state.isAdmin"
                        ownEmployeeId="state.ownEmployeeId"
                        onValidateShift.bind="validateShift"
                        onCancelShift.bind="cancelShift"
                        onDeleteShift.bind="deleteShift"
                        onEditShift.bind="editShift"/>
          <ShiftTable shifts="state.shifts"
                      employees="state.employees"
                      weekStart="state.weekStart"
                      onSetState.bind="_setShiftState"
                      onDelete.bind="deleteShift"
                      onEdit.bind="editShift"/>

          <div t-if="state.isAdmin" class="rp-manager-tools">
              <div class="rp-side-card">
                <h3>Édition manuelle</h3>
                <p class="rp-side-copy">
                  Ajuster, déplacer ou compléter la proposition automatique avant validation.
                </p>
                <div class="rp-shift-form">
                  <label>
                    <span>Employé</span>
                    <select t-att-value="state.shiftEditor.employee_id || ''"
                            t-on-change="(ev) => updateShiftEditor('employee_id', parseInt(ev.target.value || 0, 10) || false)">
                      <option value="">Sélectionner…</option>
                      <option t-foreach="orderedEmployees" t-as="emp" t-key="emp.id"
                              t-att-value="emp.id">
                        <t t-esc="emp.name"/>
                      </option>
                    </select>
                  </label>
                  <label>
                    <span>Date</span>
                    <input type="date"
                           t-att-value="state.shiftEditor.date"
                           t-on-change="(ev) => updateShiftEditor('date', ev.target.value)"/>
                  </label>
                  <label>
                    <span>Début</span>
                    <select t-att-value="state.shiftEditor.start_time"
                            t-on-change="(ev) => updateShiftEditor('start_time', parseFloat(ev.target.value))">
                      <option t-foreach="formOptions()" t-as="opt" t-key="opt.value"
                              t-att-value="opt.value">
                        <t t-esc="opt.label"/>
                      </option>
                    </select>
                  </label>
                  <label>
                    <span>Fin</span>
                    <select t-att-value="state.shiftEditor.end_time"
                            t-on-change="(ev) => updateShiftEditor('end_time', parseFloat(ev.target.value))">
                      <option t-foreach="formOptions().slice(1)" t-as="opt" t-key="opt.value"
                              t-att-value="opt.value">
                        <t t-esc="opt.label"/>
                      </option>
                    </select>
                  </label>
                  <label>
                    <span>État</span>
                    <select t-att-value="state.shiftEditor.state"
                            t-on-change="(ev) => updateShiftEditor('state', ev.target.value)">
                      <option t-foreach="shiftStateOptions" t-as="shiftState" t-key="shiftState"
                              t-att-value="shiftState">
                        <t t-esc="shiftState"/>
                      </option>
                    </select>
                  </label>
                  <label class="is-full">
                    <span>Notes</span>
                    <textarea rows="3"
                              t-on-input="(ev) => updateShiftEditor('notes', ev.target.value)"><t t-esc="state.shiftEditor.notes"/></textarea>
                  </label>
                </div>
                <div class="rp-shift-form-actions">
                  <button class="refuge-btn refuge-btn-primary"
                          t-att-disabled="state.savingShift or !state.shiftEditor.employee_id or !state.shiftEditor.date"
                          t-on-click="saveShift">
                    <t t-if="state.savingShift">Enregistrement…</t>
                    <t t-elif="state.shiftEditor.id">Mettre à jour le shift</t>
                    <t t-else="">Ajouter le shift</t>
                  </button>
                  <button class="refuge-btn refuge-btn-ghost"
                          t-on-click="cancelShiftEditor">
                    Réinitialiser
                  </button>
                </div>
              </div>

              <div class="rp-side-card">
                <h3>Contrôles automatiques</h3>
                <ul class="rp-side-list">
                  <li>Pas de shift le lundi.</li>
                  <li>Maximum 10h par jour et par employé.</li>
                  <li>11h minimum entre deux shifts.</li>
                  <li>24h hebdomadaires contractuelles respectées.</li>
                  <li>Couverture continue des horaires 10h–01h.</li>
                </ul>
              </div>

              <div t-if="state.lastReport and state.lastReport.uncovered and state.lastReport.uncovered.length"
                   class="rp-uncovered">
                <h4>Créneaux à traiter</h4>
                <ul>
                  <li t-foreach="state.lastReport.uncovered.slice(0, 24)" t-as="u" t-key="u_index">
                    <t t-esc="u"/>
                  </li>
                </ul>
                <p t-if="state.lastReport.uncovered.length > 24" class="rp-uncovered-more">
                  … +<t t-esc="state.lastReport.uncovered.length - 24"/> autres
                </p>
              </div>
          </div>
        </section>

        <section t-if="state.tab === 'avail'" class="rp-tab-pane">
          <p class="rp-avail-intro">
            Disponibilités par <strong>demi-heure</strong> sur toute l'amplitude
            d'ouverture du bar. Cliquer sur le bouton <strong>Statut</strong>
            d'un jour pour le basculer disponible / indisponible, ou sur une
            case horaire pour activer / désactiver ce créneau précis.
          </p>
          <div class="rp-avail-info">
            <t t-if="state.isAdmin">
              <strong>Gérant.</strong> Vous éditez les disponibilités de tous
              les employés ; elles alimentent la génération automatique.
            </t>
            <t t-else="">
              <strong>Édition personnelle.</strong> Vous ne modifiez que votre
              propre ligne ; les autres sont en lecture seule.
            </t>
          </div>
          <AvailabilityHeatmap employees="state.employees"
                               availabilities="state.availabilities"
                               ownEmployeeId="state.ownEmployeeId"
                               isAdmin="state.isAdmin"
                               onSetMask.bind="onAvailMask"/>
        </section>

        <section t-if="state.tab === 'me'" class="rp-tab-pane">
          <MySpace employees="state.employees"
                   shifts="state.shifts"
                   availabilities="state.availabilities"
                   weekStart="state.weekStart"
                   ownEmployeeId="state.ownEmployeeId"
                   isAdmin="state.isAdmin"
                   onGoToAvailabilities="() => this.setTab('avail')"/>
        </section>

      </div>
    </div>
  </t>

</templates>
