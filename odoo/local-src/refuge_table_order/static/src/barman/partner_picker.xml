<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="refuge_table_order.PartnerPicker">
    <div class="refuge-modal-overlay" t-on-click="props.onClose">
      <div class="refuge-modal" t-on-click.stop="">
        <header class="refuge-modal-head">
          <h3>Associer un client — Table <t t-esc="props.order.table"/></h3>
          <button class="refuge-btn refuge-btn-ghost" t-on-click="props.onClose">✕</button>
        </header>

        <div class="refuge-modal-body">
          <section class="refuge-modal-section">
            <h4>Rechercher un client existant</h4>
            <input type="text" placeholder="Nom, email ou téléphone…"
                   t-att-value="state.query"
                   t-on-input="updateQuery" class="refuge-input"/>
            <div t-if="state.searching" class="refuge-modal-meta">Recherche…</div>
            <ul class="refuge-partner-list" t-if="state.results.length">
              <li t-foreach="state.results" t-as="p" t-key="p.id">
                <div class="refuge-partner-info">
                  <strong><t t-esc="p.name"/></strong>
                  <div t-if="p.email or p.phone" class="refuge-partner-contact">
                    <span t-if="p.email"><t t-esc="p.email"/></span>
                    <span t-if="p.email and p.phone"> · </span>
                    <span t-if="p.phone"><t t-esc="p.phone"/></span>
                  </div>
                  <div t-if="p.loyalty_points" class="refuge-partner-loyalty">
                    <t t-esc="p.loyalty_points"/> pts
                    <span t-if="p.loyalty_expired" class="refuge-tag-warn">expirés</span>
                  </div>
                </div>
                <button class="refuge-btn refuge-btn-primary"
                        t-on-click="() => this.attach(p.id)">Associer</button>
              </li>
            </ul>
            <div t-if="!state.searching and state.query and !state.results.length"
                 class="refuge-modal-empty">Aucun client trouvé — créez-en un ci-dessous.</div>
          </section>

          <section class="refuge-modal-section">
            <h4>Créer un nouveau client</h4>
            <div class="refuge-modal-form">
              <input type="text" placeholder="Nom complet *" class="refuge-input"
                     t-att-value="state.newPartner.name"
                     t-on-input="(ev) => this.updateNew('name', ev)"/>
              <input type="email" placeholder="Email" class="refuge-input"
                     t-att-value="state.newPartner.email"
                     t-on-input="(ev) => this.updateNew('email', ev)"/>
              <input type="tel" placeholder="Téléphone" class="refuge-input"
                     t-att-value="state.newPartner.phone"
                     t-on-input="(ev) => this.updateNew('phone', ev)"/>
              <button class="refuge-btn refuge-btn-primary"
                      t-on-click="createAndAttach"
                      t-att-disabled="state.creating">
                <t t-if="state.creating">Création…</t>
                <t t-else="">Créer et associer</t>
              </button>
            </div>
          </section>

          <div t-if="state.error" class="refuge-modal-error">Erreur : <t t-esc="state.error"/></div>
        </div>
      </div>
    </div>
  </t>

</templates>
