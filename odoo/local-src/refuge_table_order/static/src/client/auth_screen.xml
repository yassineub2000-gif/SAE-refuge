<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="refuge_table_order.AuthScreen">
    <div class="refuge-auth">

      <div t-if="state.mode === 'choice'" class="refuge-auth-choices">
        <div class="refuge-auth-hero">
          <div class="refuge-auth-hero-badge">🍸</div>
          <h2 class="refuge-auth-title">Avant de commander…</h2>
          <p class="refuge-auth-lead">Identifiez-vous pour cumuler et utiliser vos
            <span class="refuge-auth-hl">points fidélité</span>, ou continuez en invité.</p>
        </div>

        <button class="refuge-auth-option refuge-auth-option-primary"
                t-on-click="() => this.show('login')">
          <span class="refuge-auth-option-icon">👤</span>
          <span class="refuge-auth-option-text">
            <span class="refuge-auth-option-title">J'ai déjà un compte</span>
            <span class="refuge-auth-option-sub">Connexion avec votre code à 4-6 chiffres</span>
          </span>
          <span class="refuge-auth-option-arrow">→</span>
        </button>

        <button class="refuge-auth-option"
                t-on-click="() => this.show('signup')">
          <span class="refuge-auth-option-icon">✨</span>
          <span class="refuge-auth-option-text">
            <span class="refuge-auth-option-title">Créer un compte</span>
            <span class="refuge-auth-option-sub">1 point par € dépensé, dès la 1ʳᵉ commande</span>
          </span>
          <span class="refuge-auth-option-arrow">→</span>
        </button>

        <div class="refuge-auth-sep"><span>ou</span></div>

        <button class="refuge-auth-option refuge-auth-option-ghost"
                t-on-click="props.onGuest">
          <span class="refuge-auth-option-icon">🥤</span>
          <span class="refuge-auth-option-text">
            <span class="refuge-auth-option-title">Continuer en invité</span>
            <span class="refuge-auth-option-sub">Commander sans compte ni points fidélité</span>
          </span>
          <span class="refuge-auth-option-arrow">→</span>
        </button>
      </div>

      <h2 t-else="" class="refuge-auth-title">Avant de commander…</h2>

      <form t-if="state.mode === 'login' or state.mode === 'signup'"
            class="refuge-auth-form"
            t-on-submit.prevent="submit">
        <div class="refuge-auth-form-head">
          <button type="button" class="refuge-auth-back" t-on-click="() => this.show('choice')">← Retour</button>
          <h3 t-esc="state.mode === 'login' ? 'Connexion' : 'Création de compte'"/>
        </div>

        <label class="refuge-auth-field" t-if="state.mode === 'signup'">
          <span>Nom</span>
          <input type="text" t-model="state.name" required="required" autocomplete="name"/>
        </label>
        <label class="refuge-auth-field">
          <span>Email</span>
          <input type="email" t-model="state.email" required="required" autocomplete="email"/>
        </label>
        <label class="refuge-auth-field">
          <span>Code à 4-6 chiffres</span>
          <input type="text" inputmode="numeric" pattern="[0-9]{4,6}" minlength="4" maxlength="6"
                 t-model="state.pin" required="required" autocomplete="off"/>
        </label>

        <div t-if="state.error" class="refuge-auth-error"><t t-esc="state.error"/></div>

        <button type="submit" class="refuge-btn refuge-btn-primary refuge-auth-submit"
                t-att-disabled="state.loading">
          <t t-if="state.loading">Patientez…</t>
          <t t-else=""><t t-esc="state.mode === 'login' ? 'Se connecter' : 'Créer le compte'"/></t>
        </button>
      </form>
    </div>
  </t>

</templates>
