<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
  <!-- Produit technique utilisé pour matérialiser la remise fidélité dans
       pos.order_line (prix négatif). Pas vendu, juste référencé par l'API. -->
  <record id="product_loyalty_discount" model="product.product">
    <field name="name">Remise fidélité</field>
    <field name="type">service</field>
    <field name="available_in_pos">True</field>
    <field name="sale_ok">False</field>
    <field name="purchase_ok">False</field>
    <field name="list_price">0.0</field>
    <field name="taxes_id" eval="[(5, 0, 0)]"/>
  </record>
</odoo>
