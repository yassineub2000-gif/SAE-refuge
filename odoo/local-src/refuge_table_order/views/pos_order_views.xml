<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_pos_order_tree_refuge" model="ir.ui.view">
    <field name="name">pos.order.tree.refuge</field>
    <field name="model">pos.order</field>
    <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet" position="inside">
        <group string="Commande sur table" name="refuge_group">
          <field name="refuge_source"/>
          <field name="refuge_table_id"/>
          <field name="refuge_kitchen_status"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
