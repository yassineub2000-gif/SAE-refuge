<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!--
    Pages HTML standalone qui hébergent les bundles OWL. Chaque <head>
    applique le thème AVANT le rendu (anti-flash) : lit le choix mémorisé
    (localStorage 'refuge-theme'), sinon suit la préférence système.
  -->

  <template id="theme_boot" name="Refuge — boot thème (anti-flash)">
    <script type="text/javascript">(function(){try{var k='refuge-theme',t=localStorage.getItem(k);if(!t){t=(window.matchMedia&amp;&amp;window.matchMedia('(prefers-color-scheme: dark)').matches)?'dark':'light';}document.documentElement.setAttribute('data-theme',t);}catch(e){}})();</script>
  </template>

  <template id="client_page" name="Refuge — Commande sur table">&lt;!DOCTYPE html&gt;
    <html t-att-data-table-token="table_token">
      <head>
        <title>Le Refuge des Aventuriers — Table <t t-out="table_number"/></title>
        <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1"/>
        <meta http-equiv="content-type" content="text/html; charset=utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no"/>
        <meta name="apple-mobile-web-app-capable" content="yes"/>
        <t t-call="refuge_table_order.theme_boot"/>
        <script type="text/javascript">
          var odoo = <t t-out="json.dumps({
            'csrf_token': request.csrf_token(None),
            '__session_info__': request.env['ir.http'].session_info(),
            'debug': debug,
          })"/>;
          odoo.loadMenusPromise = Promise.resolve();
          window.REFUGE_TABLE = {
            token: <t t-out="json.dumps(table_token)"/>,
            number: <t t-out="json.dumps(table_number)"/>,
            label: <t t-out="json.dumps(table_label)"/>,
          };
        </script>
        <t t-call-assets="refuge_table_order.assets_client"/>
      </head>
      <body class="refuge-client">
        <div id="refuge-root"/>
      </body>
    </html>
  </template>

