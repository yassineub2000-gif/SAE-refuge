<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!--
    Deux pages HTML standalone hébergent les bundles OWL :
    - client_page : sert le bundle refuge_table_order.assets_client
    - barman_page : sert le bundle refuge_table_order.assets_barman
    Les deux pages sont minimales (un div de montage) et injectent la session
    pour que le framework web se bootstrap correctement.
  -->

  <template id="client_page" name="Refuge — Commande sur table">&lt;!DOCTYPE html&gt;
    <html t-att-data-table-token="table_token">
      <head>
        <title>Le Refuge des Aventuriers — Table <t t-out="table_number"/></title>
        <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1"/>
        <meta http-equiv="content-type" content="text/html; charset=utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no"/>
        <meta name="apple-mobile-web-app-capable" content="yes"/>
        <script type="text/javascript">
          var odoo = <t t-out="json.dumps({
            'csrf_token': request.csrf_token(None),
            '__session_info__': request.env['ir.http'].session_info(),
            'debug': debug,
          })"/>;
          odoo.loadMenusPromise = Promise.resolve();
          window.REFUGE_TABLE = {
            token: <t t-out="json.dumps(table_token)"/>,
            number: <t t-out="json.dumps(table_number)"/>,
            label: <t t-out="json.dumps(table_label)"/>,
          };
        </script>
        <t t-call-assets="refuge_table_order.assets_client"/>
      </head>
      <body class="refuge-client">
        <div id="refuge-root"/>
      </body>
    </html>
  </template>

  <template id="barman_page" name="Refuge — Espace barman">&lt;!DOCTYPE html&gt;
    <html>
      <head>
        <title>Le Refuge des Aventuriers — Espace barman</title>
        <meta http-equiv="content-type" content="text/html; charset=utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1"/>
        <script type="text/javascript">
          var odoo = <t t-out="json.dumps({
            'csrf_token': request.csrf_token(None),
            '__session_info__': request.env['ir.http'].session_info(),
            'debug': debug,
          })"/>;
          odoo.loadMenusPromise = Promise.resolve();
        </script>
        <t t-call-assets="refuge_table_order.assets_barman"/>
      </head>
      <body class="refuge-barman">
        <div id="refuge-root"/>
      </body>
    </html>
  </template>
</odoo>
