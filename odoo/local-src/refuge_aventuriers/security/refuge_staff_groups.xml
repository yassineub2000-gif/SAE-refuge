<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!--
    Groupe métier "Refuge / Staff".
    Les employés sont des utilisateurs internes (pour lire/écrire pos.order,
    res.partner, planning via les apps OWL) mais sans accès au back-office :
    le contrôleur redirige /web vers /refuge pour ce groupe (cf. controllers).
  -->
  <record id="module_category_refuge" model="ir.module.category">
    <field name="name">Refuge</field>
    <field name="sequence">90</field>
  </record>

  <record id="group_refuge_staff" model="res.groups">
    <field name="name">Staff (tablette)</field>
    <field name="category_id" ref="module_category_refuge"/>
    <field name="comment">Employés du bar : accès aux apps tablette
      (Planning, Espace barman, Clients), pas au back-office Odoo.</field>
    <!--
      Groupes impliqués nécessaires aux apps tablette :
       - POS : lire/écrire pos.order (Espace barman, historique Clients) ;
       - Création de contact : éditer/créer des fiches clients (app Clients) ;
       - RH (officier) : lire les champs planning des fiches employé
         (refuge_weekly_hours…) et écrire les disponibilités/shifts.
      Le back-office reste masqué par la redirection /web → /refuge.
    -->
    <field name="implied_ids" eval="[(4, ref('point_of_sale.group_pos_user')),
                                     (4, ref('base.group_partner_manager')),
                                     (4, ref('hr.group_hr_user'))]"/>
  </record>
</odoo>
