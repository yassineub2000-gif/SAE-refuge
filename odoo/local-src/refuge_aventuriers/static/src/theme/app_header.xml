<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="refuge_aventuriers.AppHeader">
    <header class="rf-header">
      <a t-if="props.showBack" class="rf-header-back" t-att-href="backHref"
         aria-label="Retour à l'accueil" title="Accueil">←</a>
      <div class="rf-header-titles">
        <div class="rf-header-title"><t t-esc="props.title"/></div>
        <div t-if="props.subtitle" class="rf-header-sub"><t t-esc="props.subtitle"/></div>
      </div>
      <div class="rf-header-actions">
        <span t-if="props.userName" class="rf-header-user"><t t-esc="props.userName"/></span>
        <button class="rf-iconbtn" type="button" t-on-click="toggleTheme"
                t-att-title="ui.theme === 'dark' ? 'Passer en thème clair' : 'Passer en thème sombre'"
                aria-label="Basculer le thème clair/sombre">
          <t t-esc="ui.theme === 'dark' ? '☀' : '☾'"/>
        </button>
        <a t-if="props.showLogout" class="rf-iconbtn"
           href="/web/session/logout?redirect=/web/login"
           title="Déconnexion" aria-label="Déconnexion">⏻</a>
      </div>
    </header>
  </t>

</templates>
